{
  "runtime": {
    "mode": "local-files"
  },
  "paths": {
    "stateFile": "state/state.example.json",
    "allowlistFile": "config/allowlist.example.json",
    "localReportDirectory": "samples/reports"
  },
  "imap": {
    "host": "imap.example.com",
    "port": 993,
    "username": "replace-me@example.com",
    "password": "replace-me",
    "mailbox": "INBOX",
    "filterSubjectContains": [
      "Report domain",
      "Report Domain"
    ],
    "filterFromContains": [
      "noreply-dmarc-support@google.com",
      "dmarcreport@microsoft.com"
    ],
    "filterToContains": []
  },
  "rules": {
    "alertOnUnknownSender": true,
    "alertOnUnexpectedProvider": true,
    "alertOnSpfFailure": true,
    "alertOnDkimFailure": true,
    "alertOnAlignmentFailure": true
  },
  "senderIdentity": {
    "enableReverseDns": true,
    "approvedProviders": [
      "AWS"
    ],
    "providerPatternsFile": "config/providers.json"
  }
}
